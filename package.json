{
  "name": "@cadcrawl/cad-browser",
  "version": "0.4.1",
  "description": "Local engineering file browser with CAD and PDF previews powered by cad-toolbox.",
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/cadcrawl/cad-browser#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cadcrawl/cad-browser.git"
  },
  "bugs": {
    "url": "https://github.com/cadcrawl/cad-browser/issues"
  },
  "keywords": [
